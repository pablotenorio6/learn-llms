# API
API_PORT=8000
API_LOG_LEVEL=INFO
API_KEYS=dev-key-changeme
API_REQUIRE_AUTH=false

# LiteLLM proxy (control plane: routing, keys, costes)
LITELLM_BASE_URL=http://litellm:4000
LITELLM_MASTER_KEY=sk-llmops-changeme

# Credenciales de proveedores cloud (vacías => solo modelos locales disponibles)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama (solo lo lee el contenedor de Ollama; la API ya no le habla directo)
OLLAMA_KEEP_ALIVE=10m

# Modelos por defecto (usan los alias definidos en litellm-config.yaml)
DEFAULT_CHAT_MODEL=qwen-local
DEFAULT_EMBED_MODEL=nomic-embed

# Bench (alias del proxy; añade gpt-4o-mini, claude-haiku-4-5, etc. cuando tengas keys)
BENCH_MODELS=llama-local,qwen-local,phi-local

# ----- RAG -----
QDRANT_HOST=http://qdrant:6333
RAG_COLLECTION=llmops_docs
RAG_EMBED_DIM=768                 # nomic-embed-text → 768; bge-base → 768; bge-large → 1024
RAG_CHUNK_SIZE=1000               # caracteres por chunk
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=5                       # nº de chunks a recuperar por query
RAG_DOCS_DIR=/app/docs            # carpeta vigilada por el watcher (dentro del contenedor)
RAG_WATCHER_ENABLED=true

# ----- Web tools (agente) -----
# Brave Search API key — consíguela en https://api.search.brave.com (2000 queries/mes gratis).
# Sin key, la tool web_search devolverá un error claro.
BRAVE_API_KEY=
BRAVE_ENDPOINT=https://api.search.brave.com/res/v1/web/search
WEB_SEARCH_TIMEOUT=10.0
WEB_SEARCH_MAX_RESULTS=10           # tope superior, el modelo puede pedir menos
HTTP_FETCH_TIMEOUT=10.0
HTTP_FETCH_MAX_BYTES=2000000        # 2 MB tope de descarga
HTTP_FETCH_MAX_CHARS=8000           # texto limpio devuelto al modelo
HTTP_FETCH_USER_AGENT=llmops-agent/0.1 (+https://github.com/local)
