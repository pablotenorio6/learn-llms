# API
API_PORT=8000
API_LOG_LEVEL=INFO
API_KEYS=dev-key-changeme
API_REQUIRE_AUTH=false

# LiteLLM proxy (control plane: routing, keys, costes)
LITELLM_BASE_URL=http://litellm:4000
LITELLM_MASTER_KEY=sk-llmops-changeme

# Credenciales de proveedores cloud (vacías => solo modelos locales disponibles)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama (solo lo lee el contenedor de Ollama; la API ya no le habla directo)
OLLAMA_KEEP_ALIVE=10m

# Modelos por defecto (usan los alias definidos en litellm-config.yaml)
DEFAULT_CHAT_MODEL=qwen-local
DEFAULT_EMBED_MODEL=nomic-embed

# Bench (alias del proxy; añade gpt-4o-mini, claude-haiku-4-5, etc. cuando tengas keys)
BENCH_MODELS=llama-local,qwen-local,phi-local

# ----- RAG -----
QDRANT_HOST=http://qdrant:6333
RAG_COLLECTION=llmops_docs
RAG_EMBED_DIM=768                 # nomic-embed-text → 768; bge-base → 768; bge-large → 1024
RAG_CHUNK_SIZE=1000               # caracteres por chunk
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=5                       # nº de chunks a recuperar por query
RAG_DOCS_DIR=/app/docs            # carpeta vigilada por el watcher (dentro del contenedor)
RAG_WATCHER_ENABLED=true

# ----- Observabilidad (Fase 2) -----
# Langfuse self-hosted v2. Las keys salen de la UI de Langfuse la primera vez
# que arrancas el stack (Settings → API keys) o se pueden semillar via env de
# init en el contenedor langfuse (ver docker-compose.yml).
LANGFUSE_ENABLED=true
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-llmops-public
LANGFUSE_SECRET_KEY=sk-lf-llmops-secret-changeme
LANGFUSE_LOG_PAYLOADS=true

# Postgres detrás de Langfuse (sólo lo usa el propio Langfuse, no la API).
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=langfuse-changeme
LANGFUSE_DB_NAME=langfuse

# Secretos de Langfuse (>=32 chars; genera con `openssl rand -hex 32`).
LANGFUSE_NEXTAUTH_SECRET=changeme-nextauth-secret-replace-me-32-chars-min
LANGFUSE_SALT=changeme-salt-replace-me-32-chars-minimum

# Usuario admin auto-creado al primer boot (Langfuse v2 INIT vars).
# El validador de Langfuse exige email con TLD: admin@local NO sirve.
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=changeme-admin-pass

# Prometheus / Grafana
METRICS_ENABLED=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ----- Web tools (agente) -----
# Brave Search API key — consíguela en https://api.search.brave.com (2000 queries/mes gratis).
# Sin key, la tool web_search devolverá un error claro.
BRAVE_API_KEY=
BRAVE_ENDPOINT=https://api.search.brave.com/res/v1/web/search
WEB_SEARCH_TIMEOUT=10.0
WEB_SEARCH_MAX_RESULTS=10           # tope superior, el modelo puede pedir menos
HTTP_FETCH_TIMEOUT=10.0
HTTP_FETCH_MAX_BYTES=2000000        # 2 MB tope de descarga
HTTP_FETCH_MAX_CHARS=8000           # texto limpio devuelto al modelo
HTTP_FETCH_USER_AGENT=llmops-agent/0.1 (+https://github.com/local)

# ----- Compute / system tools (agente) -----
# Workspace jail compartido por las tools filesystem (fs_*) y python_exec.
# Bind-mounted desde ./sandbox (ver docker-compose.yml).
TOOLS_SANDBOX_DIR=/app/sandbox
FS_MAX_READ_BYTES=256000
FS_MAX_WRITE_BYTES=256000
# python_exec: subproceso aislado con rlimits + timeout. NO es un sandbox de
# seguridad contra código adversarial (el blast radius es el contenedor api).
PYTHON_EXEC_TIMEOUT=10.0
PYTHON_EXEC_MAX_OUTPUT=8000
PYTHON_EXEC_MAX_MEMORY_MB=256
